# ── Database ────────────────────────────────────────────────
# Path to the shared SQLite file. LEAVE UNSET for local development:
# both apps then default to <repo>/data/app.db regardless of cwd.
# docker-compose sets /data/app.db explicitly. If you do set it,
# use an absolute path (relative paths resolve from each app's cwd).
#DATABASE_PATH=

# ── Web app ─────────────────────────────────────────────────
# Public origin of the site (used in emails and absolute links)
SITE_URL=http://localhost:3000
# Prod only (Caddy): bare hostname enables automatic HTTPS,
# e.g. SITE_DOMAIN=dash.example.com. Unset = plain HTTP on port 80.
#SITE_DOMAIN=

# ── First admin (used by `npm run seed:admin`) ──────────────
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me

# ── SMTP for one-time login codes ───────────────────────────
# Leave SMTP_HOST empty in development: codes print to the web
# server console instead of sending email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Healthtech Dashboard <no-reply@example.com>"

# ── Pipeline ────────────────────────────────────────────────
# Identify yourself to SEC EDGAR (they require a descriptive UA)
SEC_USER_AGENT="healthtech-dashboard/1.0 (contact: you@example.com)"
